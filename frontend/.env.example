# If set, the browser calls this URL directly (needs CORS on the backend for your frontend origin).
# Production: REQUIRED — e.g. https://api.yourdomain.com (no trailing slash; do not duplicate /api here).
# If empty, Next.js proxies /api/* to INTERNAL_API_PROXY (default http://127.0.0.1:5000) — local dev only.
NEXT_PUBLIC_API_URL=
# Optional override when NEXT_PUBLIC_API_URL is empty (full rewrite destination pattern):
# INTERNAL_API_PROXY=http://127.0.0.1:5000/api/:path*
NEXT_PUBLIC_APP_NAME=Grocery POS System
NEXT_PUBLIC_APP_VERSION=1.0.0

# Firebase (required for inventory-only mode)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
