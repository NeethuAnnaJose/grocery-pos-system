{
  "name": "grocery-pos-frontend",
  "version": "1.0.0",
  "description": "Grocery Shop Management & POS System Frontend",
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "dev:http": "next dev -H 0.0.0.0 -p 3000",
    "dev:https": "next dev --experimental-https -H 0.0.0.0 -p 3000",
    "tunnel": "lt --port 3000 --local-host 127.0.0.1",
    "tunnel:fixed": "lt --port 3000 --local-host 127.0.0.1 --subdomain groceryposadmin",
    "tunnel:fixed:3001": "lt --port 3001 --local-host 127.0.0.1 --subdomain groceryposadmin",
    "dev:tunnel": "concurrently -k -n APP,TUNNEL -c cyan,magenta \"pnpm run dev:http\" \"pnpm run tunnel\"",
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true});console.log('cleaned .next')}catch(e){console.log(e.message)}\"",
    "mobile:stable": "pnpm run clean && next build && next start -H 0.0.0.0 -p 3000",
    "mobile:stable:tunnel": "concurrently -k -n APP,TUNNEL -c cyan,magenta \"pnpm run mobile:stable\" \"pnpm run tunnel\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@reduxjs/toolkit": "^2.0.1",
    "@zxing/library": "^0.21.3",
    "axios": "^1.6.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "firebase": "^12.12.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.294.0",
    "next": "^14.0.4",
    "react": "^18.2.0",
    "react-barcode": "^1.5.1",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.48.2",
    "react-hot-toast": "^2.4.1",
    "react-qr-scanner": "^1.0.0-alpha.1",
    "react-query": "^3.39.3",
    "react-redux": "^9.0.4",
    "recharts": "^2.8.0",
    "redux-persist": "^6.0.0",
    "tailwind-merge": "^2.2.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.0.4",
    "localtunnel": "^2.0.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3"
  }
}
