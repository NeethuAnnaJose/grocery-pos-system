# Database
DATABASE_URL="postgresql://username:password@localhost:5432/grocery_pos"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"
RESET_TOKEN_EXPIRES_IN="15m"

# Server
PORT=5000
NODE_ENV="development"

# Email (for invoices and notifications)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"
EMAIL_FROM="Grocery POS <your-email@gmail.com>"

# Shop Details
SHOP_NAME="Grocery Shop"
SHOP_ADDRESS="123 Main Street, City, State 123456"
SHOP_PHONE="+91 9876543210"
SHOP_GSTIN="27AAAPL1234C1ZV"

# Printer Settings
THERMAL_PRINTER_NAME="Thermal Printer"
THERMAL_PRINTER_WIDTH=80

# CORS — browser origin(s) of the Next.js app (scheme + host + port, no path). Comma-separated for multiple.
# Production example: FRONTEND_URL="https://pos.yourdomain.com,https://www.yourdomain.com"
FRONTEND_URL="http://localhost:3000"
# Optional extra allowed origins (comma-separated), e.g. staging URL or a second storefront.
# CORS_EXTRA_ORIGINS=
# Set to true only if you need Vercel preview URLs (*.vercel.app) to call this API.
# CORS_ALLOW_VERCEL_PREVIEW=false
